{
  "name": "plataforma-lingua-portuguesa",
  "version": "1.0.0",
  "private": true,
  "description": "Atividades escolares de Lingua Portuguesa com quiz e jogo de trilha.",
  "scripts": {
    "serve": "node tools/serve.js",
    "serve:quiz": "npm --prefix apps/quiz-portugues run serve",
    "serve:trilha": "npm --prefix apps/trilha-das-habilidades run serve",
    "check": "npm run check:apps && npm run check:source && npm run lint && npm run format:check && npm run test:e2e && npm run test:layout",
    "check:apps": "npm run check:quiz && npm run check:trilha",
    "check:quiz": "npm --prefix apps/quiz-portugues run check",
    "check:trilha": "npm --prefix apps/trilha-das-habilidades run check",
    "check:source": "node tools/check-project.js",
    "lint": "npm run lint:js",
    "lint:js": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:contract": "node tools/validate-contract.js",
    "validate:trilha": "node tools/validate-trilha-data.js",
    "test:e2e": "node tools/run-e2e.js",
    "test:layout": "node tools/run-e2e.js tests/e2e/layout.spec.js --workers=1",
    "test:visual": "node tools/run-e2e.js --grep @visual --pass-with-no-tests",
    "build:static": "node tools/build-static.js",
    "build:quiz": "npm --prefix apps/quiz-portugues run build",
    "build:trilha": "npm --prefix apps/trilha-das-habilidades run build",
    "preview": "node tools/serve.js dist"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3"
  }
}
